# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=ton_token_discord_ici

# ── football-data.org (gratuit) ───────────────────────────────────────────────
# Clé gratuite sur : https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=ta_cle_ici

# ── Channels Discord ──────────────────────────────────────────────────────────
# Clic droit sur le channel → "Copier l'identifiant"
# (active le mode développeur dans Discord : Paramètres → Avancé → Mode développeur)
RESULTS_CHANNEL_ID=123456789012345678
MATCHES_CHANNEL_ID=123456789012345678

# ── Serveur Discord (guild) ───────────────────────────────────────────────────
# Clic droit sur le nom du serveur → "Copier l'identifiant"
# Recommandé : les commandes slash apparaissent instantanément au lieu de ~1h
GUILD_ID=123456789012345678

# ── Optionnel ─────────────────────────────────────────────────────────────────
DB_PATH=worldcup.db

# ── Propriétaire du bot (seul autorisé à utiliser /setscore) ─────────────────
# Clique droit sur ton pseudo Discord → "Copier l'identifiant" (mode développeur requis)
OWNER_ID=ton_id_discord_ici
